# Supabase — get from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: override the default model (google/gemini-flash-1.5)
# Other good cheap vision models:
#   google/gemini-2.0-flash-exp:free   (free tier, rate limited)
#   anthropic/claude-3-haiku            (via OpenRouter)
#   meta-llama/llama-3.2-11b-vision-instruct:free
# OPENROUTER_MODEL=google/gemini-flash-1.5
